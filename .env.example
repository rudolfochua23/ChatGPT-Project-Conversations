# Copy this file to .env and fill in your values
# cp .env.example .env

NODE_ENV=production
PORT=4173
SESSION_SECRET=generate-a-random-64-char-string-here
COOKIE_SECURE=true
COOKIE_DOMAIN=your-domain.com

# PostgreSQL
DATABASE_URL=postgresql://aichats:your-pg-password@db:5432/aichats
PG_USER=aichats
PG_PASSWORD=your-pg-password

# Initial admin account (only used on first run)
APP_ADMIN_USERNAME=admin
APP_ADMIN_EMAIL=admin@your-domain.com
APP_ADMIN_PASSWORD=change-this-strong-password

# SMTP for email verification & password reset
# If unset, emails are printed to console (useful for dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@your-domain.com

# Base URL for password reset links
APP_URL=https://your-domain.com

# Docker image (for production compose)
DOCKER_IMAGE=your-dockerhub-username/ai-chats:latest
