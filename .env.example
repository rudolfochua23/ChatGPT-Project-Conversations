# Copy this file to .env and fill in your values
# cp .env.example .env

NODE_ENV=production
PORT=4173
SESSION_SECRET=generate-a-random-64-char-string-here
COOKIE_SECURE=true
COOKIE_DOMAIN=chatpileai.yourdomain.com

# PostgreSQL
DATABASE_URL=postgresql://aichats:your-pg-password@db:5432/aichats
PG_USER=aichats
PG_PASSWORD=your-pg-password

# Initial admin account (only used on first run)
APP_ADMIN_USERNAME=admin
APP_ADMIN_EMAIL=admin@chatpileai.yourdomain.com
APP_ADMIN_PASSWORD=change-this-strong-password

# SMTP for email verification & password reset
# If unset, emails are printed to console (useful for dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@chatpileai.yourdomain.com

# Base URL for password reset links
APP_URL=https://chatpileai.yourdomain.com

# S3-compatible storage (MinIO or AWS S3)
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_BUCKET=aichats

# Xendit payment gateway (for premium subscriptions)
# Get keys from: https://dashboard.xendit.co/settings/developers#api-keys
XENDIT_SECRET_KEY=
XENDIT_CALLBACK_TOKEN=
XENDIT_PLAN_AMOUNT=200
XENDIT_PLAN_CURRENCY=PHP

# Docker image (for production compose)
DOCKER_IMAGE=your-dockerhub-username/chatpileai:latest
